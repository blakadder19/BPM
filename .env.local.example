# Data provider: "memory" (default, in-memory mock stores) or "supabase" (real DB)
DATA_PROVIDER=memory

# Supabase (required when DATA_PROVIDER=supabase)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Academy timezone — used by datetime logic for class start/end, late cancel,
# attendance closure, and check-in windows. Does NOT depend on Vercel's TZ var.
APP_TIMEZONE=Europe/Dublin

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Brevo) — optional. If not set, BPM app email is silently disabled.
# Sign up at https://brevo.com. Create an API key under SMTP & API > API Keys.
# BREVO_API_KEY=xkeysib-your-api-key-here
# EMAIL_FROM_ADDRESS=BPM <noreply@yourdomain.com>
#
# Brevo is also used for Supabase Auth emails (signup, reset password, etc.)
# via custom SMTP. See supabase/config.toml [auth.email.smtp] for local dev
# and Supabase Dashboard > Authentication > SMTP Settings for production.

# Stripe — optional. If not set, "Pay online" is hidden and only reception checkout is available.
# Create keys at https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_your_secret_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# For local dev: run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# and copy the webhook signing secret from the CLI output.

# Dev-only: comma-separated emails that always see dev tools when authenticated
# DEV_TOOL_ALLOWED_EMAILS=you@example.com
